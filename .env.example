# Core platform
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
API_BASE_URL=http://localhost:3000
PLAYWRIGHT_BASE_URL=http://localhost:3000
E2E_TRADESPERSON_EMAIL=
E2E_TRADESPERSON_PASSWORD=

# AI / embeddings
GEMINI_API_KEY=gemini-api-key

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_PROPERTIES_COLLECTION=properties
QDRANT_ESTIMATES_COLLECTION=estimates

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly
STRIPE_PRO_ANNUAL_PRICE_ID=price_pro_annual
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_agency_monthly
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_agency_annual

# Container smoke tests (optional)
RUN_CONTAINER_SMOKE=0
STRIPE_MOCK_HOST=127.0.0.1
STRIPE_MOCK_PORT=12111
