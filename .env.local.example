# =============================================================================
# Refurb Estimator — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (required for auth, database, and storage)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# OpenAI (required for AI photo estimate)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# ---------------------------------------------------------------------------
# Google Gemini (required for AI pricing & design agents)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# Optional: dedicated keys for pricing and design agents (fall back to GEMINI_API_KEY)
# GEMINI_PRICING_API_KEY=your-gemini-pricing-key
# GEMINI_DESIGN_API_KEY=your-gemini-design-key

# ---------------------------------------------------------------------------
# Backend Designer Agent (optional)
# ---------------------------------------------------------------------------
# OPENAI_DESIGNER_MODEL=gpt-4.1

# ---------------------------------------------------------------------------
# Client-side API base URL (optional, defaults to empty string for same-origin)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE_URL=

# ---------------------------------------------------------------------------
# Capacitor / Mobile (optional, defaults to production Vercel URL)
# ---------------------------------------------------------------------------
# CAPACITOR_SERVER_URL=https://refurb-estimator.vercel.app

# ---------------------------------------------------------------------------
# Perplexity Agent Proxy (used by .mcp.json, set in shell env)
# ---------------------------------------------------------------------------
# PERPLEXITY_AGENT_TOKEN=agp_your-token-here
