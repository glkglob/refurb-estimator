# =============================================================================
# Refurb Estimator — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (required — auth, database, storage)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---------------------------------------------------------------------------
# OpenAI (required — embeddings and AI photo estimate)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
# Override the designer model (optional, default: gpt-4.1)
OPENAI_DESIGNER_MODEL=gpt-4.1
# Override upload metadata model (optional, default: gpt-4.1-mini)
OPENAI_DESIGN_METADATA_MODEL=gpt-4.1-mini

# AI upload workflow (optional overrides)
SUPABASE_DESIGN_UPLOAD_BUCKET=design-uploads
DESIGN_SIGNED_URL_EXPIRY_SECONDS=3600

# ---------------------------------------------------------------------------
# Hugging Face (required — AI pricing & design agents)
# ---------------------------------------------------------------------------
HUGGINGFACE_PRICING_API_KEY=hf_your-pricing-api-key
HUGGINGFACE_REFURB_DESIGN_KEY=hf_your-design-api-key

# ---------------------------------------------------------------------------
# Qdrant (required — property vector search)
# ---------------------------------------------------------------------------
QDRANT_URL=https://your-cluster-id.eu-central.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_PROPERTIES_COLLECTION=properties

# ---------------------------------------------------------------------------
# Stripe (required — checkout, portal, and webhook processing)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Price IDs from your Stripe dashboard (Products > Pricing)
STRIPE_PRO_MONTHLY_PRICE_ID=price_your-pro-monthly-id
STRIPE_PRO_ANNUAL_PRICE_ID=price_your-pro-annual-id
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_your-agency-monthly-id
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_your-agency-annual-id

# ---------------------------------------------------------------------------
# App environment (optional)
# ---------------------------------------------------------------------------
# Set to "development" locally, "production" on Vercel
NEXT_PUBLIC_APP_ENV=development
APP_ENV=development

# ---------------------------------------------------------------------------
# Local AI provider override (optional — dev only, replaces OpenAI)
# ---------------------------------------------------------------------------
# AI_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=qwen/qwen3-4b

# ---------------------------------------------------------------------------
# Telemetry / observability sampling (optional)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_ASSISTANT_UI_SAMPLE_RATE=1.0
# ASSISTANT_OBSERVABILITY_SAMPLE_RATE=1.0

# ---------------------------------------------------------------------------
# Storage / AWS S3 (optional — for image upload)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_S3_BUCKET=your-s3-bucket
# AWS_REGION=eu-west-2

# ---------------------------------------------------------------------------
# Backend Designer Agent (optional — legacy, not used in Next.js routes)
# ---------------------------------------------------------------------------
