# =============================================================================
# Refurb Estimator — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (required for auth, database, and storage)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# Storage / AWS S3
# ---------------------------------------------------------------------------
NEXT_PUBLIC_S3_BUCKET=your-s3-bucket
AWS_REGION=eu-west-2

# ---------------------------------------------------------------------------
# OpenAI (required for AI photo estimate)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# ---------------------------------------------------------------------------
# Hugging Face (required for AI pricing & design agents)
# ---------------------------------------------------------------------------
HUGGINGFACE_PRICING_API_KEY=hf_your-pricing-api-key
HUGGINGFACE_REFURB_DESIGN_KEY=hf_your-design-api-key

# Model overrides (optional — defaults shown)
HUGGINGFACE_DESIGN_MODEL=meta-llama/Llama-3.3-70B-Instruct
HUGGINGFACE_PRICING_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ---------------------------------------------------------------------------
# Backend Designer Agent (optional)
# ---------------------------------------------------------------------------